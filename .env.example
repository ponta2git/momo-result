# API
APP_ENV=dev
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
IMAGE_TMP_DIR=${TMPDIR:-/tmp}/momo-result/uploads
DATABASE_URL=
DATABASE_USER=
DATABASE_PASSWORD=
DB_POOL_SIZE=8

# Resource limits
UPLOAD_RATE_LIMIT_PER_MINUTE=20
UPLOAD_REQUEST_MAX_BYTES=3211264
SOURCE_IMAGE_DOWNLOAD_RATE_LIMIT_PER_MINUTE=60
SOURCE_IMAGE_ARCHIVE_MAX_BYTES=10485760
IMAGE_UPLOAD_UNREFERENCED_COUNT_LIMIT=24
IMAGE_UPLOAD_UNREFERENCED_BYTES_LIMIT=67108864
IMAGE_UPLOAD_STORAGE_MIN_FREE_BYTES=268435456
IMAGE_UPLOAD_STORAGE_MAX_USED_PERCENT=90
IMAGE_ORPHAN_OLDER_THAN_MINUTES=15
IMAGE_ORPHAN_REAPER_INTERVAL_MINUTES=5
REQUEST_MAX_BYTES=262144
EXPORT_RATE_LIMIT_PER_MINUTE=30
EXPORT_ALL_RATE_LIMIT_PER_MINUTE=6
EXPORT_MAX_ROWS=20000
EXPORT_MAX_BYTES=16777216
OCR_JOB_CREATE_RATE_LIMIT_PER_MINUTE=10
OCR_JOB_CREATE_GLOBAL_RATE_LIMIT_PER_MINUTE=20
OCR_ACTIVE_JOB_LIMIT=12

# Logging (api)
# MOMO_LOG_FORMAT: "json" (single-line JSON, default/prod) or "text" (human readable, local dev)
MOMO_LOG_FORMAT=text
MOMO_LOG_LEVEL=INFO

# Discord OAuth / server-side session
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=
AUTH_STATE_SIGNING_KEY=
SESSION_COOKIE_NAME=momo_result_session
OAUTH_STATE_COOKIE_NAME=momo_result_oauth_state
SESSION_TTL_DAYS=30
OAUTH_STATE_TTL_SECONDS=300
AUTH_RATE_LIMIT_PER_MINUTE=10
AUTH_CALLBACK_REDIRECT_PATH=/
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_HOST_PREFIX=false

# Redis (OCR queue)
REDIS_URL=redis://localhost:6379/0
OCR_REDIS_STREAM=momo:ocr:jobs
OCR_REDIS_GROUP=momo-ocr-workers
OCR_REDIS_DEAD_LETTER_STREAM=momo:ocr:jobs:dead
OCR_OUTBOX_DUE_BACKLOG_LIMIT=24
OCR_OUTBOX_ACTIVE_BACKLOG_LIMIT=48
OCR_OUTBOX_OLDEST_DUE_MAX_DELAY_SECONDS=600
OCR_DEAD_LETTER_BACKLOG_LIMIT=24

# Local web development
VITE_DEV_USER=
