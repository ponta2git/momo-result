# API
APP_ENV=dev
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
IMAGE_TMP_DIR=${TMPDIR:-/tmp}/momo-result/uploads
DATABASE_URL=
DATABASE_USER=
DATABASE_PASSWORD=
DB_POOL_SIZE=8

# Logging (api)
# MOMO_LOG_FORMAT: "json" (single-line JSON, default/prod) or "text" (human readable, local dev)
MOMO_LOG_FORMAT=text
MOMO_LOG_LEVEL=INFO

# Discord OAuth / server-side session
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=
AUTH_STATE_SIGNING_KEY=
SESSION_COOKIE_NAME=momo_result_session
OAUTH_STATE_COOKIE_NAME=momo_result_oauth_state
SESSION_TTL_DAYS=30
OAUTH_STATE_TTL_SECONDS=300
AUTH_RATE_LIMIT_PER_MINUTE=10
AUTH_CALLBACK_REDIRECT_PATH=/
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_HOST_PREFIX=false

# Redis (OCR queue)
REDIS_URL=redis://localhost:6379/0
OCR_REDIS_STREAM=momo:ocr:jobs
OCR_REDIS_GROUP=momo-ocr-workers

# Local web development
VITE_DEV_USER=
