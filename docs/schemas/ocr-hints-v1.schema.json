{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://momo-result.local/schemas/ocr-hints-v1.schema.json",
  "title": "OCR hints v1",
  "type": "object",
  "properties": {
    "gameTitle": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "layoutFamily": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "knownPlayerAliases": {
      "type": "array",
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["memberId", "aliases"],
        "properties": {
          "memberId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 128
          },
          "aliases": {
            "type": "array",
            "minItems": 1,
            "maxItems": 8,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64
            }
          }
        },
        "additionalProperties": false
      }
    },
    "computerPlayerAliases": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      }
    }
  },
  "additionalProperties": false
}
