{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "oxlint --react-plugin --jsx-a11y-plugin . && node ./scripts/check-architecture-imports.mjs",
    "lint:fix": "oxlint --react-plugin --jsx-a11y-plugin . --fix",
    "lint:react-perf": "oxlint --react-plugin --react-perf-plugin src --ignore-pattern \"**/*.test.*\" --ignore-pattern \"**/__tests__/**\"",
    "lint:react-perf:all": "oxlint --react-plugin --react-perf-plugin .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "generate:api": "node ./scripts/generate-api.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@conform-to/react": "^1.19.1",
    "@conform-to/zod": "^1.19.1",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.9",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.1",
    "msw": "^2.14.5",
    "openapi-typescript": "^7.13.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.63.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
