{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "pnpm run generate:api",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "e2e": "node ./scripts/e2e-isolated.mjs",
    "e2e:target": "playwright test",
    "e2e:target:ui": "playwright test --ui",
    "e2e:ui": "node ./scripts/e2e-isolated.mjs --ui",
    "preview": "vite preview",
    "pretypecheck": "pnpm run generate:api",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest",
    "pretest:coverage": "pnpm run generate:api",
    "test:coverage": "vitest run --coverage",
    "pretest:coverage:report": "pnpm run generate:api",
    "test:coverage:report": "COVERAGE_REPORT_ONLY=1 vitest run --coverage",
    "pretest:run": "pnpm run generate:api",
    "test:run": "vitest run",
    "prelint": "pnpm run generate:api",
    "lint": "oxlint --react-plugin --jsx-a11y-plugin . && node ./scripts/check-architecture-imports.mjs && node ./scripts/check-api-contract.mjs",
    "lint:fix": "oxlint --react-plugin --jsx-a11y-plugin . --fix",
    "lint:react-perf": "oxlint --react-plugin --react-perf-plugin src --ignore-pattern \"**/*.test.*\" --ignore-pattern \"**/__tests__/**\"",
    "lint:react-perf:all": "oxlint --react-plugin --react-perf-plugin .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "generate:api": "node ./scripts/generate-api.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-query": "^5.101.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "openapi-typescript": "^7.13.0",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "testcontainers": "^12.0.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
